# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=CompliVibe
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development default)
DATABASE_URL=sqlite:///./complivibe.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/complivibe

# ── Vector Store (Qdrant) ─────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Embeddings / LLM ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ── Ingestion ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
